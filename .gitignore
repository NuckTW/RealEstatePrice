# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# Python
__pycache__/
*.pyc
venv/
.venv/

# 暫存資料（不上傳原始 CSV）
data/*.csv
data/*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.github/workflows/scraper.yml
