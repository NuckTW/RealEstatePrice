{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "ui_kits/dashboard/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono|Noto Sans TC))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono, Noto Sans TC."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|dot|pulse|className|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, variant, dot, pulse, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:brass|clay|positive|info|warning|negative|neutral)$/]",
        "message": "<Badge> tone must be one of 'brass' | 'clay' | 'positive' | 'info' | 'warning' | 'negative' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:solid|count)$/]",
        "message": "<Badge> variant must be one of 'solid' | 'count'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|loading|disabled|icon|className|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, loading, disabled, icon, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|children|sql|className|style|key|ref|className|style|children)$/]",
        "message": "<ChatBubble> doesn't accept that prop. Declared props: role, children, sql, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChatBubble'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:user|assistant)$/]",
        "message": "<ChatBubble> role must be one of 'user' | 'assistant'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|children|className|style|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: checked, onChange, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|icon|tone|delta|className|style|key|ref|className|style|children)$/]",
        "message": "<KpiCard> doesn't accept that prop. Declared props: label, value, unit, icon, tone, delta, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|count|actions|flush|children|className|style|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: title, count, actions, flush, children, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|options|value|onChange|className|style|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, options, value, onChange, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|pct|color|align|minWidth|className|style|key|ref|className|style|children)$/]",
        "message": "<StatBar> doesn't accept that prop. Declared props: value, pct, color, align, minWidth, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBar'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right)$/]",
        "message": "<StatBar> align must be one of 'left' | 'right'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabPills'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|value|onChange|className|style|key|ref|className|style|children)$/]",
        "message": "<TabPills> doesn't accept that prop. Declared props: tabs, value, onChange, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|onRemove|className|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, onRemove, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|size|className|style|wrapStyle|key|ref|className|style|children)$/]",
        "message": "<TextInput> doesn't accept that prop. Declared props: icon, size, className, style, wrapStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextInput'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|lg)$/]",
        "message": "<TextInput> size must be one of 'sm' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ThemeToggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|onChange|labels|className|style|key|ref|className|style|children)$/]",
        "message": "<ThemeToggle> doesn't accept that prop. Declared props: value, onChange, labels, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TypingDots'] > JSXAttribute > JSXIdentifier[name!=/^(?:className|style|key|ref|className|style|children)$/]",
        "message": "<TypingDots> doesn't accept that prop. Declared props: className, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
